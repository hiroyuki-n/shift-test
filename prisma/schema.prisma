// ============================================================
//  シフト管理システム  Prisma Schema
//  対象: 50店舗 / 約1,000人規模 マルチテナント飲食店向け
//  DB  : PostgreSQL (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // アプリ実行時はConnection Pooling、マイグレーションはDirect Connectionを使用
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
//  Enum 定義
// ============================================================

/// ユーザー権限
enum Role {
  SUPER_ADMIN // 本社全体管理（店舗追加、全データ閲覧・編集）
  SHOP_ADMIN // 店長（自店舗の管理・スタッフ追加・シフト編集）
  STAFF // 一般スタッフ（希望シフト提出・確定シフト確認）
}

/// 店舗への所属種別（メイン店舗 or ヘルプ/応援）
enum MembershipType {
  PRIMARY // メイン所属店舗
  SUPPORT // ヘルプ（応援）で所属する店舗
}

/// 雇用形態（アルバイト or 社員）
enum EmploymentType {
  PART_TIME // アルバイト
  FULL_TIME // 社員
}

/// 希望シフトの承認ステータス
enum ShiftStatus {
  PENDING // 申請中（未処理）
  APPROVED // 承認済み
  REJECTED // 却下
}

/// 確定シフトでのポジション/役割
enum Position {
  HALL // ホール
  KITCHEN // キッチン
  CASHIER // レジ
  MANAGER // 管理（店長業務など）
  OTHER // その他
}

// ============================================================
//  Model 定義
// ============================================================

/// ユーザー（本社管理者・店長・スタッフ）
model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  role      Role     @default(STAFF)
  // 雇用形態（アルバイト/社員）。管理者など雇用形態を持たない場合は null
  employmentType EmploymentType?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // メイン店舗（任意）。SUPER_ADMIN は本社所属のため null を許容
  primaryShopId String? @db.Uuid
  primaryShop   Shop?   @relation("PrimaryShopMembers", fields: [primaryShopId], references: [id], onDelete: SetNull)

  // 多対多: ヘルプ含む全所属店舗（中間テーブル ShopMembership 経由）
  shopMemberships ShopMembership[]

  // このユーザーが提出した希望シフト
  shiftRequests ShiftRequest[]

  // このユーザーに割り当てられた確定シフト
  finalShifts FinalShift[]

  // このユーザーが確定させた（作成した）シフト（店長操作の監査用）
  createdFinalShifts FinalShift[] @relation("FinalShiftCreatedBy")

  @@index([role])
  @@index([employmentType])
  @@index([primaryShopId])
  @@index([email])
  @@map("users")
}

/// 店舗
model Shop {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // メイン店舗としてこの店舗に所属するユーザー
  primaryMembers User[] @relation("PrimaryShopMembers")

  // 多対多: この店舗に所属する全ユーザー（ヘルプ含む）
  memberships ShopMembership[]

  // この店舗に紐づく希望シフト・確定シフト
  shiftRequests ShiftRequest[]
  finalShifts   FinalShift[]

  @@index([name])
  @@index([isActive])
  @@map("shops")
}

/// 中間テーブル: ユーザー × 店舗（多対多 / ヘルプ応援対応）
model ShopMembership {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  shopId String @db.Uuid

  // 所属種別（メイン or ヘルプ）
  type MembershipType @default(PRIMARY)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // 同一ユーザーが同一店舗に重複所属しないよう一意制約
  @@unique([userId, shopId])
  @@index([shopId])
  @@index([userId])
  @@index([type])
  @@map("shop_memberships")
}

/// 希望シフト（スタッフが提出）
model ShiftRequest {
  id        String      @id @default(uuid()) @db.Uuid
  // 対象日（日付のみ）
  date      DateTime    @db.Date
  startTime DateTime    @db.Timestamptz(6)
  endTime   DateTime    @db.Timestamptz(6)
  status    ShiftStatus @default(PENDING)
  note      String? // スタッフからの備考

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 提出者
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 希望対象の店舗（自店舗 or ヘルプ先）
  shopId String @db.Uuid
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // 大量データ・絞り込み検索用の複合インデックス
  @@index([shopId, date])
  @@index([userId, date])
  @@index([status])
  @@index([date])
  @@map("shift_requests")
}

/// 確定シフト（店長が確定）
model FinalShift {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @db.Date
  startTime DateTime @db.Timestamptz(6)
  endTime   DateTime @db.Timestamptz(6)
  position  Position @default(HALL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // アサインされたスタッフ
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 対象店舗
  shopId String @db.Uuid
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // 確定操作を行った店長（監査用 / 任意）
  createdById String? @db.Uuid
  createdBy   User?   @relation("FinalShiftCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // カレンダー表示・集計用の複合インデックス
  @@index([shopId, date])
  @@index([userId, date])
  @@index([date])
  @@index([position])
  @@map("final_shifts")
}
